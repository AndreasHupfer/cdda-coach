# Lokale CDDA-Konfiguration (nicht committet)
# Kopiere diese Datei nach .env und passe die Werte an deine Installation an.

# Pfad zur CDDA-Installation (Root-Verzeichnis, nicht das save/-Unterverzeichnis)
CDDA_ROOT=/pfad/zu/deinem/cdda/game

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...
